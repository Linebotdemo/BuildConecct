@app.post("/upload-blueprint", status_code=201)
async def upload_blueprint(project_id: int = Form(...), name: str = Form(...), file: UploadFile = File(...),
                           db: Session = Depends(get_db), current_user: dict = Depends(get_current_user)):
    company_id = current_user.get("company_id")
    os.makedirs("files/blueprints", exist_ok=True)
    file_extension = file.filename.split(".")[-1]
    unique_filename = f"{uuid.uuid4()}.{file_extension}"
    file_path = f"files/blueprints/{unique_filename}"
    with open(file_path, "wb") as f:
        f.write(await file.read())
    blueprint_data = {
        "project_id": project_id,
        "name": name,
        "filename": unique_filename,
        "file_path": file_path,
        "company_id": company_id
    }
    new_bp = create_blueprint(db, blueprint_data)
    return {"id": new_bp.id, "name": new_bp.name, "file_path": new_bp.file_path}

