@app.post("/line/webhook")
async def line_webhook(request: Request, db: Session = Depends(get_db)):
    signature = request.headers.get("X-Line-Signature")
    body = await request.body()
    try:
        events = parser.parse(body.decode(), signature)
    except InvalidSignatureError:
        raise HTTPException(status_code=400, detail="Invalid signature")
    for event in events:
        if isinstance(event, MessageEvent):
            user_id = event.source.user_id
            line_user = get_line_user(db, user_id)
            if not line_user:
                profile = line_api.get_profile(user_id)
                line_user = create_line_user(db, user_id, profile.display_name)
            if isinstance(event.message, TextMessage):
                text = event.message.text.strip()
                if not line_user.registered:
                    if not line_user.temp_company_code:
                        company = get_company_by_code(db, text)
                        if company:
                            update_line_user(db, line_user, {"temp_company_code": company.company_code, "current_state": "selecting_project"})
                            projects = get_projects(db, company_id=company.id)
                            if projects:
                                buttons = [QuickReplyButton(action=MessageAction(label=p.name[:20], text=str(p.id))) for p in projects[:13]]
                                line_api.reply_message(event.reply_token, TextSendMessage(
                                    text="プロジェクトを選択してください",
                                    quick_reply=QuickReply(items=buttons)
                                ))
                            else:
                                line_api.reply_message(event.reply_token, TextSendMessage(text="この会社にプロジェクトがありません"))
                        else:
                            line_api.reply_message(event.reply_token, TextSendMessage(text="会社コードが正しくありません。もう一度入力してください"))
                    elif line_user.current_state == "selecting_project":
                        try:
                            project_id = int(text)
                            project = db.query(Project).filter(Project.id == project_id, Project.company_id == db.query(Company).filter(Company.company_code == line_user.temp_company_code).first().id).first()
                            if project:
                                update_line_user(db, line_user, {
                                    "company_code": line_user.temp_company_code,
                                    "project_id": project_id,
                                    "registered": True,
                                    "temp_company_code": None,
                                    "current_state": None
                                })
                                line_api.reply_message(event.reply_token, TextSendMessage(text=f"登録が完了しました！\n会社: {project.company.company_name}\nプロジェクト: {project.name}"))
                            else:
                                line_api.reply_message(event.reply_token, TextSendMessage(text="無効なプロジェクトIDです"))
                        except ValueError:
                            line_api.reply_message(event.reply_token, TextSendMessage(text="プロジェクトIDを数値で入力してください"))
                else:
                    report_data = {
                        "project_id": line_user.project_id,
                        "report_text": text,
                        "company_id": db.query(Company).filter(Company.company_code == line_user.company_code).first().id,
                        "reporter": line_user.line_user_name
                    }
                    create_report(db, report_data)
                    line_api.reply_message(event.reply_token, TextSendMessage(text="レポートを受け付けました"))
            elif isinstance(event.message, ImageMessage):
                if line_user.registered:
                    message_content = line_api.get_message_content(event.message.id)
                    file_extension = "jpg" if event.message.content_type == "image/jpeg" else "png"
                    unique_filename = f"{uuid.uuid4()}.{file_extension}"
                    file_path = f"files/photos/{unique_filename}"
                    os.makedirs("files/photos", exist_ok=True)
                    with open(file_path, "wb") as f:
                        f.write(message_content.content)
                    report_data = {
                        "project_id": line_user.project_id,
                        "report_text": "画像レポート",
                        "photo_url": file_path,
                        "company_id": db.query(Company).filter(Company.company_code == line_user.company_code).first().id,
                        "reporter": line_user.line_user_name
                    }
                    create_report(db, report_data)
                    line_api.reply_message(event.reply_token, TextSendMessage(text="画像レポートを受け付けました"))
    return {"status": "ok"}

# WebSocket for real-time updates
class ConnectionManager:
    def __init__(self):
        self.active_connections: List[WebSocket] = []

    async def connect(self, websocket: WebSocket):
        await websocket.accept()
        self.active_connections.append(websocket)

    def disconnect(self, websocket: WebSocket):
        self.active_connections.remove(websocket)

    async def send_personal_message(self, message: str, websocket: WebSocket):
        await websocket.send_text(message)

    async def broadcast(self, message: str):
        for connection in self.active_connections:
            await connection.send_text(message)

manager = ConnectionManager()

@app.websocket("/ws")
async def websocket_endpoint(websocket: WebSocket):
    await manager.connect(websocket)
    try:
        while True:
            data = await websocket.receive_text()
            await manager.broadcast(f"Message: {data}")
    except WebSocketDisconnect:
        manager.disconnect(websocket)
        await manager.broadcast("A client disconnected")