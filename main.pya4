@app.get("/orders")
async def list_orders(db: Session = Depends(get_db), current_user: dict = Depends(get_current_user)):
    company_id = current_user.get("company_id")
    orders = db.query(Order).options(joinedload(Order.project)).filter(Order.company_id == company_id).all()
    result = [
        {
            "id": o.id,
            "order_number": o.order_number or "-",
            "project_id": o.project_id,
            "project_name": o.project.name if o.project else None,
            "material": o.material,
            "quantity": o.quantity,
            "order_status": o.order_status,
            "surplus": o.surplus,
            "storage": o.storage,
            "order_date": o.order_date.isoformat() if o.order_date else None,
            "delivery_date": o.delivery_date.isoformat() if o.delivery_date else None,
            "supplier_name": o.supplier_name,
            "price": o.price,
            "total_price": o.total_price,
            "updated_by": o.updated_by
        } for o in orders
    ]
    logger.debug(f"Orders returned: {len(result)} items")
    return result

@app.post("/orders", status_code=201)
async def create_order_endpoint(order: OrderCreateSchema, db: Session = Depends(get_db), current_user: dict = Depends(get_current_user)):
    order_data = order.dict()
    order_data["company_id"] = current_user.get("company_id")
    order_data["updated_by"] = current_user.get("username")
    new_order = create_order(db, order_data)
    return {"id": new_order.id, "order_number": new_order.order_number}

@app.put("/orders/{order_id}")
async def update_order_endpoint(order_id: int, order_update: OrderSchema, db: Session = Depends(get_db), current_user: dict = Depends(get_current_user)):
    order_data = order_update.dict(exclude_unset=True)
    order_data["updated_by"] = current_user.get("username")
    updated = update_order(db, order_id, order_data, current_user.get("company_id"))
    if not updated:
        raise HTTPException(status_code=404, detail="Order not found")
    if updated.order_status == "delivered":
        update_inventory_for_order(db, updated, current_user.get("username"))
    return {"id": updated.id, "order_number": updated.order_number}

